rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update, delete: if isOwner(userId);
    }

    match /projects/{projectId} {
      allow get: if true;
      allow list: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
    }
    
    match /clients/{clientId} {
      allow read: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
    }
    
    match /versions/{versionId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if true;
      allow delete: if isAuthenticated();
    }
    
    match /feedback/{feedbackId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAuthenticated();
    }
    
    match /project_assets/{assetId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAuthenticated();
    }
    
    match /change_requests/{requestId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }
  }
}
