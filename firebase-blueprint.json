{
  "entities": {
    "User": {
      "title": "User",
      "description": "Admin/creator profile settings.",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "website": { "type": "string" },
        "contactEmail": { "type": "string" },
        "brandColor": { "type": "string" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "A review portal project for a client.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "password": { "type": "string" },
        "maxRevisions": { "type": "number" },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["title", "password", "maxRevisions", "creatorId", "createdAt"]
    },
    "Version": {
      "title": "Version",
      "description": "A specific draft of the project content.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "versionNumber": { "type": "number" },
        "driveLink": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "photo"] },
        "creatorNotes": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "changes_requested"] },
        "isCurrent": { "type": "boolean" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["projectId", "versionNumber", "driveLink", "type", "status", "isCurrent", "createdAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "Client feedback or approval for a version.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "versionId": { "type": "string" },
        "changesRequested": { "type": "array", "items": { "type": "string" } },
        "editType": { "type": "string", "enum": ["major", "minor", "approval"] },
        "clientNotes": { "type": "string" },
        "nextStep": { "type": "string", "enum": ["post_social", "provide_download", "request_more_edits", "finalize", "none"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["projectId", "versionId", "editType", "createdAt"]
    },
    "ProjectAsset": {
      "title": "Project Asset",
      "description": "Essential elements uploaded by client.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "data": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["projectId", "fileName", "data", "createdAt"]
    },
    "ChangeRequest": {
      "title": "Change Request",
      "description": "Individual change requested by the client.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "versionId": { "type": "string" },
        "text": { "type": "string" },
        "isMajor": { "type": "boolean" },
        "reviewerName": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["projectId", "versionId", "text", "isMajor", "reviewerName", "completed", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores admin/creator profiles."
    },
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Stores project details."
    },
    "versions/{versionId}": {
      "schema": "Version",
      "description": "Stores versions of projects."
    },
    "feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "Stores client feedback."
    },
    "project_assets/{assetId}": {
      "schema": "ProjectAsset",
      "description": "Stores client uploaded assets."
    },
    "change_requests/{requestId}": {
      "schema": "ChangeRequest",
      "description": "Stores individual change requests."
    }
  }
}
